{
  "name": "group-trip-planner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply group-trip-planner-db",
    "db:migrate:local": "wrangler d1 migrations apply group-trip-planner-db --local",
    "db:seed": "wrangler d1 execute group-trip-planner-db --local --file=src/db/seed.sql",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.79.0"
  }
}
